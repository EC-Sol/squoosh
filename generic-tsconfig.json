{
  "compilerOptions": {
    "target": "ES2019",
    "downlevelIteration": true,
    "module": "esnext",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "moduleResolution": "node",

    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,

    "baseUrl": "./",
    "rootDir": "./",

    "paths": {
      "static-build/*": ["src/static-build/*"],
      "client/*": ["src/client/*"],
      "shared/*": ["src/shared/*"],
      "features/*": ["src/features/*"],
      "worker-shared/*": ["src/worker-shared/*"]
    }
  }
}
