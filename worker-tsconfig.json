{
  "extends": "./generic-tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "lib": [
      "webworker",
      "esnext"
    ],
    "outDir": ".tmp/tsc-output"
  },
  "include": [
    "src/features/**/worker/**/*",
    "src/features/**/shared/**/*",
    "src/features/worker-utils/**/*",
    "src/features-worker/**/*",
    "src/worker-shared/**/*"
  ],
  "exclude": [
    "src/sw"
  ]
}