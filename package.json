{
  "private": true,
  "name": "squoosh",
  "version": "2.1.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "description": "Squoosh Desktop App",
  "author": "Hansol Yu <yhs1203@gmail.com>",
  "license": "apache-2.0",
  "main": "electron.js",
  "scripts": {
    "build": "rollup -c && node lib/move-output.js",
    "debug": "node --inspect-brk node_modules/.bin/rollup -c",
    "dev": "DEV_PORT=5000 run-p watch serve",
    "watch": "rollup -cw",
    "serve": "serve --listen=5050 --config ../../../serve.json .tmp/build/static",
    "prepare": "husky install",
    "start:electron": "node_modules\\.bin\\electron.cmd .",
    "dist": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.squoosh.app",
    "files": [
      "electron.js",
      "build/**/*"
    ],
    "win": {
      "target": "portable",
      "signAndEditExecutable": false,
      "icon": "src/static-build/assets/icon-large.png"
    },
    "linux": {
      "target": [
        "rpm",
        "AppImage"
      ],
      "icon": "src/static-build/assets/icon-large.png",
      "category": "Utility"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-image": "^3.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@rollup/plugin-url": "^8.0.2",
    "@surma/rollup-plugin-off-main-thread": "^2.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/dedent": "^0.7.2",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.10.2",
    "@web/rollup-plugin-import-meta-assets": "^2.3.0",
    "comlink": "^4.4.2",
    "cssnano": "^7.1.2",
    "dedent": "^1.7.0",
    "del": "^8.0.1",
    "electron": "^39.2.6",
    "electron-builder": "26.3.5",
    "file-drop-element": "^1.0.1",
    "glob": "^13.0.0",
    "husky": "^9.1.7",
    "idb-keyval": "^6.2.2",
    "image-size": "^2.0.2",
    "linkstate": "^2.0.1",
    "lint-staged": "^16.2.7",
    "lodash.camelcase": "^4.3.0",
    "mime-types": "^3.0.2",
    "npm-run-all": "^4.1.5",
    "pointer-tracker": "^2.5.3",
    "postcss": "^8.5.6",
    "postcss-modules": "^6.0.1",
    "postcss-nested": "^7.0.2",
    "postcss-simple-vars": "^7.0.1",
    "postcss-url": "^10.1.3",
    "preact": "^10.28.0",
    "preact-render-to-string": "^6.6.3",
    "prettier": "^3.7.4",
    "rollup": "^4.53.3",
    "rollup-plugin-postcss": "^4.0.2",
    "serve": "^14.2.5",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "wasm-feature-detect": "^1.8.0",
    "which": "^6.0.0"
  },
  "lint-staged": {
    "*.{js,css,json,md,ts,tsx}": "prettier --write",
    "*.{c,h,cpp,hpp}": "clang-format -i",
    "*.rs": "rustfmt"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
