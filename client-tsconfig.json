{
  "extends": "./generic-tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "lib": [
      "esnext",
      "dom",
      "dom.iterable"
    ],
    "types": [],
    "outDir": ".tmp/tsc-output"
  },
  "include": [
    "src/features/**/client/**/*",
    "src/features/**/shared/**/*",
    "src/features/client-utils/**/*",
    "src/shared/**/*",
    "src/client/**/*",
    "src/features/**/worker/**/*",
    "src/features-worker/**/*",
    "src/features/worker-utils/**/*",
    "src/worker-shared/**/*"
  ]
}